{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/chat",
      "destination": "/api/index.py"
    },
    {
      "source": "/voice/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/analyze/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/docs",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
