{
  "rewrites": [
    {
      "source": "/chat",
      "destination": "/api/index.py"
    },
    {
      "source": "/voice/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/analyze/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/docs",
      "destination": "/api/index.py"
    },
    {
      "source": "/openapi.json",
      "destination": "/api/index.py"
    }
  ]
}
